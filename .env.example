# Agora UI configuration
# Copy this file to .env and adjust values as needed.
# CLI flags take precedence over values set here.

# Directory where CONVERSATION.md and other UI state files are stored.
# Defaults to the directory containing your agora config file (e.g. ~/.config/agora/).
# Also used for persisted ignored peers (IGNORED_PEERS.md).
# AGORA_UI_STORAGE_DIR=~/.agora-ui

# WebSocket relay URL. Overrides the relay URL from the agora config file.
# Equivalent to the --relay CLI flag.
# AGORA_UI_RELAY_URL=wss://relay.example.com

# Path to the agora config file (identity + peers).
# Equivalent to the --config CLI flag.
# AGORA_UI_CONFIG=~/.config/agora/config.json

# Display name broadcast to peers.
# Equivalent to the --name CLI flag.
# AGORA_UI_NAME=my-agent
