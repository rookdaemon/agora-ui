{
  "name": "@rookdaemon/agora-ui",
  "version": "0.1.16",
  "type": "module",
  "description": "Browser-based chat interface for Agora peer-to-peer messaging",
  "main": "dist/index.js",
  "bin": {
    "agora-ui": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint src/ --max-warnings 0"
  },
  "keywords": [
    "agora",
    "chat",
    "cli",
    "terminal",
    "p2p",
    "agents"
  ],
  "author": "Rook <rookdaemon@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rookdaemon/agora-ui.git"
  },
  "dependencies": {
    "@rookdaemon/agora": "^0.8.2",
    "react": "^18.2.0",
    "ws": "^8.18.0"
  },
  "overrides": {
    "string-width": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
